generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         Int           @id @default(autoincrement())
  name       String
  role       String        @default("GUEST")
  createdAt  DateTime      @default(now())
  messages   ChatMessage[]
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  user      User?    @relation(fields: [userId], references: [id])
  userId    Int?
  sender    String
  role      String
  content   String
  createdAt DateTime @default(now())
}
